# ─────────────────────────────────────────────────────────────
# PLANET Style Collective Portal — environment variables
# Copy this file to ".env" for local dev, and add the same
# values in Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# --- Supabase (client-side, safe to expose) ---
# Found in Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- GoAffPro (client-side, public token is safe to expose) ---
VITE_GOAFFPRO_PUBLIC_TOKEN=5bbb5e7d83cbb8340673b1f07fa72b49606dd4e26e6e70b4737e3769d64ee814

# ─────────────────────────────────────────────────────────────
# SERVER-ONLY secrets (NO "VITE_" prefix → never sent to browser).
# Used by the /api/commissions serverless function on Vercel.
# ─────────────────────────────────────────────────────────────

# GoAffPro Admin Access Token — REQUIRED for live commission data.
# Get it in GoAffPro → Settings → Advanced Settings → API Keys.
GOAFFPRO_ACCESS_TOKEN=your-goaffpro-admin-access-token
GOAFFPRO_PUBLIC_TOKEN=5bbb5e7d83cbb8340673b1f07fa72b49606dd4e26e6e70b4737e3769d64ee814

# Supabase URL + anon key again, server-side, so the function can verify
# partner sessions before returning their (and only their) earnings.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# --- Partner Catalog (optional) ---
# The /api/products function proxies PLANET's live Shopify product feed for
# the Partner Catalog. It defaults to the PLANET storefront, so this is only
# needed to point at a different store. No secret required (public feed).
# SHOPIFY_PRODUCTS_URL=https://shopplanetbylaureng.com/products.json
